PORT=3000

# Email (Gmail: use a 16-character App Password, spaces are optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Custom SMTP (when EMAIL_SERVICE is not gmail/outlook)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Database Mode
USE_DB=false
MONGODB_URI=mongodb://127.0.0.1:27017/restaurant-management

